OTS_HTTP_REQUEST_LOG=true
OTS_HTTP_BINDING_ADDRESS=:8082
VAULT_ADDR=https://localhost:8200
VAULT_TOKEN=root
VAULT_SKIP_VERIFY=true

OTS_PASSPHRASE_NUM_WORDS_DEFAULT=5
OTS_PASSPHRASE_SEPARATOR_DEFAULT=-
OTS_PASSPHRASE_CAPITALIZE_DEFAULT=true
OTS_PASSPHRASE_INCLUDE_NUMBER_DEFAULT=true
OTS_PASSPHRASE_MAX_NUMBER_DEFAULT=9